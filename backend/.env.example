# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/verdura?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars"

# App
PORT=4000
NODE_ENV=development
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Razorpay (India payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Firebase (push notifications)
FIREBASE_PROJECT_ID=verdura-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@verdura-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Redis (BullMQ job queue) - Upstash recommended
REDIS_URL=redis://default:password@host:6379

# AWS S3 / Cloudflare R2 (image storage)
S3_BUCKET=verdura-images
S3_REGION=ap-south-1
S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx
S3_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
